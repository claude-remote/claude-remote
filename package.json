{
  "name": "claude-remote",
  "version": "999.0.0-local",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.9",
  "bin": {
    "claude-remote": "./bin/claude-remote",
    "claude-remote-hub": "./src/entrypoints/serve.ts"
  },
  "scripts": {
    "claude-remote": "./bin/claude-remote",
    "start": "./bin/claude-remote",
    "dev": "bun run src/entrypoints/serve.ts",
    "build": "bun build ./src/entrypoints/serve.ts --outdir dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "dev:web": "vite --config src/web/vite.config.ts",
    "build:web": "vite build --config src/web/vite.config.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "better-sqlite3": "^11.10.0",
    "hono": "^4.8.2",
    "postcss": "^8.5.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.2",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "typescript": "^5.8.3"
  }
}
